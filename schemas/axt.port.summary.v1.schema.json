{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "axt-port JSONL summary record",
  "type": "object",
  "required": [
    "schema",
    "type",
    "ok",
    "action",
    "ports",
    "sockets",
    "holders",
    "held",
    "freed",
    "timed_out",
    "duration_ms",
    "truncated"
  ],
  "properties": {
    "schema": { "const": "axt.port.summary.v1" },
    "type": { "const": "summary" },
    "ok": { "type": "boolean" },
    "action": { "enum": ["list", "who", "free", "watch"] },
    "ports": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
    },
    "sockets": { "type": "integer", "minimum": 0 },
    "holders": { "type": "integer", "minimum": 0 },
    "held": { "type": "boolean" },
    "freed": { "type": "boolean" },
    "timed_out": { "type": "boolean" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "truncated": { "type": "boolean" }
  },
  "additionalProperties": false
}
