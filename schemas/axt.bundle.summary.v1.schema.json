  "properties": {
    "schema": { "const": "axt.bundle.summary.v1" },
    "type": { "const": "summary" },
    "ok": { "type": "boolean" },
    "root": { "type": "string" },
    "files": { "type": "integer", "minimum": 0 },
    "dirs": { "type": "integer", "minimum": 0 },
    "manifests": { "type": "integer", "minimum": 0 },
    "git": { "type": "boolean" },
    "truncated": { "type": "boolean" },
    "next": { "type": "array", "items": { "type": "string" } }
  }
}
