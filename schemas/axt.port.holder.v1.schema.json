{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "axt-port JSONL holder record",
  "type": "object",
  "required": [
    "schema",
    "type",
    "port",
    "proto",
    "pid",
    "name",
    "cmd",
    "cwd",
    "bound",
    "owner",
    "mem",
    "started"
  ],
  "properties": {
    "schema": { "const": "axt.port.holder.v1" },
    "type": { "const": "holder" },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "proto": { "enum": ["tcp", "udp"] },
    "pid": { "type": "integer", "minimum": 0 },
    "name": { "type": "string" },
    "cmd": { "type": ["string", "null"] },
    "cwd": { "type": ["string", "null"] },
    "bound": { "type": "array", "items": { "type": "string" } },
    "owner": { "type": ["string", "null"] },
    "mem": { "type": ["integer", "null"], "minimum": 0 },
    "started": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
