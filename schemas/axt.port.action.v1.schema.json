{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "axt-port JSONL action record",
  "type": "object",
  "required": [
    "schema",
    "type",
    "port",
    "pid",
    "name",
    "signal",
    "action",
    "result",
    "ok",
    "escalated",
    "ms"
  ],
  "properties": {
    "schema": { "const": "axt.port.action.v1" },
    "type": { "const": "action" },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "pid": { "type": "integer", "minimum": 0 },
    "name": { "type": "string" },
    "signal": { "enum": ["term", "kill", "int"] },
    "action": { "enum": ["signaled", "simulated", "refused"] },
    "result": { "enum": ["freed", "held", "skipped", "permission_denied", "refused", "failed"] },
    "ok": { "type": "boolean" },
    "escalated": { "type": "boolean" },
    "ms": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
